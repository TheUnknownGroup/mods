{
  "schemaVersion": 1,
  "id": "dalib",
  "version": "${version}",
  "name": "Dalib",
  "description": "Library mod for The Unknown Group/mods needing the same capabilities.",
  "authors": [
    "devonk15"
  ],
  "contact": {},
  "entrypoints": {
    "main": [
      "io.github.theunknowngroup.Dalib"
    ]
  },
  "license": "MIT License",
  "icon": "assets/dalib/icon.png",
