        "modmenu.github_releases": "https://github.com/TheUnknownGroup/unknown-mod/releases",
        "modmenu.modrinth": "https://modrinth.com/mod/unknown-mod",
        "modmenu.discord": "https://discord.gg/jspNzHYTFn",
        "modmenu.github_sponsors": "https://github.com/sponsors/devonk15"
